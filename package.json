{
  "name": "footyviz-component-library",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "storybook": "npm run dev -w @footyviz/storybook",
    "build:storybook": "npm run build -w @footyviz/storybook",
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test -w @footyviz/storybook",
    "test:watch": "npm run test:watch -w @footyviz/storybook",
    "lint": "npm run lint --workspaces --if-present",
    "clean": "npm run clean --workspaces --if-present",
    "changeset": "changeset",
    "version-packages": "changeset version"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@changesets/cli": "2.31.0"
  }
}
